{
  "name": "pura-ai",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "tsc": "tsc --noEmit",
    "tsc:server": "tsc --noEmit -p server/tsconfig.json",
    "server:ai": "tsx --env-file=.env server/aiProxy.ts",
    "verify:ai": "tsx --env-file=.env scripts/verifyAi.ts",
    "lanip": "tsx --env-file=.env scripts/lanip.ts",
    "dev": "concurrently --kill-others-on-fail --names \"PROXY,EXPO\" --prefix-colors \"cyan,magenta\" \"npm:server:ai\" \"npm:start\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@expo/vector-icons": "^14.0.0",
    "@gorhom/bottom-sheet": "^5.0.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "@shopify/flash-list": "1.8.3",
    "date-fns": "^4.1.0",
    "expo-asset": "~12.0.12",
    "expo-blur": "~15.0.0",
    "expo-camera": "~17.0.10",
    "expo-font": "~14.0.0",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.7",
    "expo-notifications": "~0.32.11",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.0",
    "expo-video": "~3.0.11",
    "phosphor-react-native": "^2.1.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/node": "^25.6.0",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "concurrently": "^9.2.1",
    "expo": "~54.0.0",
    "npx": "^10.2.2",
    "start": "^5.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "private": true
}
