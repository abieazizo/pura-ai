{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx expo export -p web && node scripts/patch-web-index.js",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/proxy/*.ts": {
      "memory": 1024,
      "maxDuration": 90,
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    {
      "source": "/__pura_ai__/:method",
      "destination": "/api/proxy/:method"
    }
  ],
  "headers": [
    {
      "source": "/api/proxy/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/__pura_ai__/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
