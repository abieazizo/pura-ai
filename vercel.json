{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx expo export -p web && node scripts/patch-web-index.js",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/__pura_ai__/:method",
      "destination": "/api/__pura_ai__/:method"
    }
  ],
  "headers": [
    {
      "source": "/api/__pura_ai__/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
