# Pura AI â€” local dev environment template.
#
# Copy this file to `.env` (Expo auto-loads `.env` at start).
# Variables prefixed with EXPO_PUBLIC_ are inlined into the React
# Native bundle. Server-side secrets MUST stay outside that prefix.

# â”€â”€â”€ React Native client â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# URL the RN client uses to reach the AI proxy. For local dev pointing
# at the proxy started by `npm run server:ai`, this is:
EXPO_PUBLIC_PURA_AI_PROXY_URL=http://localhost:8787

# Bearer token the client attaches as `Authorization: Bearer <token>`.
# Must match `PURA_AI_PROXY_TOKEN` on the server. Leave blank for
# local dev (auth is skipped server-side when the token is empty).
EXPO_PUBLIC_PURA_AI_PROXY_TOKEN=

# Set to "1" to render the dev-only AI source badge in the running
# app. Off by default. Only turn on when actively diagnosing.
EXPO_PUBLIC_PURA_AI_DEV_BADGE=

# â”€â”€â”€ Server (proxy) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# OpenAI API key. Held server-side ONLY. Never put this behind the
# EXPO_PUBLIC_ prefix â€” it would ship into the RN bundle and leak.
# v11.0+ â€” runtime AI provider is OpenAI (gpt-5-mini for structured
# workflows, gpt-5 for grounded assistant answers).
OPENAI_API_KEY=your_openai_api_key_here

# Optional: bind host / port / token / rate limit / body size.
# Defaults are safe for local dev.
PURA_AI_PROXY_HOST=0.0.0.0
PURA_AI_PROXY_PORT=8787
PURA_AI_PROXY_TOKEN=your_proxy_token_here
PURA_AI_PROXY_RATE_PER_MIN=60
PURA_AI_PROXY_BODY_LIMIT_MB=12
