# Pura AI — local dev environment template.
#
# Copy this file to `.env` (Expo auto-loads `.env` at start) or to
# `.env.local`. Only variables prefixed with EXPO_PUBLIC_ are
# inlined into the React Native bundle by the Expo babel plugin —
# server-side keys MUST stay outside that prefix.

# ─── React Native client ─────────────────────────────────────────────
# URL the RN client uses to reach the AI proxy. For local dev pointing
# at the proxy started by `npm run server:ai`, this is:
EXPO_PUBLIC_PURA_AI_PROXY_URL=http://localhost:8787

# Bearer token the client attaches as `Authorization: Bearer <token>`.
# Must match `PURA_AI_PROXY_TOKEN` on the server. Leave blank for
# local dev (auth is skipped server-side when the token is empty).
EXPO_PUBLIC_PURA_AI_PROXY_TOKEN=

# Set to "1" to render the dev-only AI source badge in the running
# app. Off by default — the pill leaks "FALLBACK" into normal usage
# in Expo Go where __DEV__ is always true. Only turn on when actively
# diagnosing.
EXPO_PUBLIC_PURA_AI_DEV_BADGE=

# ─── Server (proxy) ──────────────────────────────────────────────────
# Anthropic API key. Held server-side ONLY. Never put this behind the
# EXPO_PUBLIC_ prefix — it would ship into the RN bundle and leak.
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXX

# Optional: bind host / port / token / rate limit / body size.
# Defaults are safe for local dev.
PURA_AI_PROXY_HOST=127.0.0.1
PURA_AI_PROXY_PORT=8787
PURA_AI_PROXY_TOKEN=
PURA_AI_PROXY_RATE_PER_MIN=60
PURA_AI_PROXY_BODY_LIMIT_MB=12
